# GLM-5 API配置
# 复制此文件为 .env 并设置您的API密钥

# GLM-5 API密钥（从 https://open.bigmodel.cn/ 获取）
GLM5_API_KEY=e217140203d34544acb721230c4f3d57.M4VERrYX2rKgB66r

# GLM模型选择
# glm-4: 基础对话模型
# glm-4-flash: 快速对话模型（推荐）
# glm-4-plus: 增强对话模型
# glm-4-air: 轻量级对话模型
GLM_MODEL=glm-4

# API温度参数 (0.0-1.0，越高越随机)
GLM_TEMPERATURE=0.7

# 最大Token数
GLM_MAX_TOKENS=2000

# API超时时间（毫秒）
GLM_TIMEOUT=30000
